@page
@model ECommerce_Project.Api.Pages.AdminProductsModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Адмін-панель | Управління товарами</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #f8f9fa;
            padding: 2rem 0;
        }
        .container-custom {
            max-width: 1400px;
            margin: 0 auto;
            padding: 0 1rem;
        }
        .card-header-custom {
            background-color: #fff;
            border-bottom: 2px solid #e9ecef;
            padding: 1rem 0;
            margin-bottom: 1.5rem;
        }
        .table th {
            background-color: #f8f9fa;
            font-weight: 600;
        }
        .form-section {
            background-color: #fff;
            border: 1px solid #dee2e6;
            border-radius: 0.5rem;
            padding: 1.5rem;
            margin-bottom: 2rem;
        }
        .form-section h3 {
            font-size: 1.25rem;
            margin-bottom: 1.25rem;
            color: #495057;
        }
        .product-name {
            font-weight: 500;
            color: #212529;
        }
        .product-price {
            font-weight: 600;
            color: #2c7da0;
        }
        .btn-sm-custom {
            padding: 0.25rem 0.75rem;
            font-size: 0.875rem;
        }
        .btn-danger-sm {
            padding: 0.25rem 0.75rem;
            font-size: 0.875rem;
        }
        .modal-backdrop-custom {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.5);
            z-index: 999;
            display: none;
        }
        .action-buttons {
            display: flex;
            gap: 0.5rem;
            flex-wrap: wrap;
        }
    </style>
</head>
<body>
    <div class="container-custom">
        <div class="card-header-custom">
            <h2 class="h4 mb-0">Управління товарами</h2>
            <p class="text-muted small mt-1 mb-0">Адмін-панель: додавання, редагування та видалення товарів</p>
        </div>

        <div id="admin-auth-error" class="alert alert-danger d-none" role="alert">
            Помилка доступу. Цей розділ доступний лише для адміністраторів.
        </div>

        <div class="form-section">
            <h3>Додати новий товар</h3>
            <form id="addProductForm">
                <div class="row g-3">
                    <div class="col-md-4">
                        <input type="text" class="form-control" id="addName" placeholder="Назва товару" required>
                    </div>
                    <div class="col-md-6">
                        <input type="text" class="form-control" id="addDesc" placeholder="Опис" required>
                    </div>
                    <div class="col-md-2">
                        <input type="number" class="form-control" id="addPrice" placeholder="Ціна" step="0.01" required>
                    </div>
                    <div class="col-md-10">
                        <input type="text" class="form-control" id="addImageUrl" placeholder="URL зображення (опціонально)">
                    </div>
                    <div class="col-md-2">
                        <input type="number" class="form-control" id="addQty" placeholder="Кількість" required>
                    </div>
                    <div class="col-md-10">
                        <select class="form-select" id="addCategorySelect" required>
                            <option value="">Оберіть категорію</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-primary w-100">Додати товар</button>
                    </div>
                </div>
            </form>
        </div>

        <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th style="width: 20%">Назва</th>
                        <th style="width: 35%">Опис</th>
                        <th style="width: 10%">Ціна</th>
                        <th style="width: 10%">Кількість</th>
                        <th style="width: 10%">Категорія</th>
                        <th style="width: 15%">Дії</th>
                    </tr>
                </thead>
                <tbody id="productsTableBody">
                    <tr>
                        <td colspan="5" class="text-center text-muted py-4">Завантаження товарів...</td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <div id="editProductModal" class="modal fade" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Редагувати товар</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="editProductId">
                    <div class="mb-3">
                        <label class="form-label">Назва</label>
                        <input type="text" class="form-control" id="editName">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Опис</label>
                        <textarea class="form-control" id="editDesc" rows="3"></textarea>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Ціна (грн)</label>
                        <input type="number" class="form-control" id="editPrice" step="0.01">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">URL зображення</label>
                        <input type="text" class="form-control" id="editImageUrl" placeholder="https://images.unsplash.com/photo-1515562141207-7a88fb7ce338?q=80&w=600">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Кількість на складі</label>
                        <input type="number" class="form-control" id="editQuantity">
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Категорія</label>
                        <select class="form-select" id="editCategorySelect">
                            <option value="">Оберіть категорію</option>
                        </select>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Скасувати</button>
                    <button type="button" class="btn btn-primary" onclick="saveChanges()">Зберегти</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        let editModal;

        document.addEventListener('DOMContentLoaded', function () {
            if (!isAdmin()) {
                document.getElementById('admin-auth-error').classList.remove('d-none');

                document.querySelector('.form-section').style.display = 'none';
                document.querySelector('.table-responsive').style.display = 'none';
                return;
            }

            editModal = new bootstrap.Modal(document.getElementById('editProductModal'));
            loadCategories();
            loadProducts(1);

            document.getElementById('addProductForm').addEventListener('submit', function (e) {
                e.preventDefault();
                addProduct();
            });
        });

        const token = localStorage.getItem('token');

        let currentPage = 1;
        let pageSize = 12;
        let totalPages = 1;

        function isAdmin() {
            if (!token) return false;
            try {
                const payload = JSON.parse(atob(token.split('.')[1]));
                const role = payload['http://schemas.microsoft.com/ws/2008/06/identity/claims/role'] || payload.role;
                return role === 'Admin';
            } catch (e) {
                return false;
            }
        }

        function loadProducts(page = 1) {
            currentPage = page;
    
            fetch(`/api/products?pageNumber=${currentPage}&pageSize=${pageSize}`)
                .then(response => response.json())
                .then(data => {
                    const tbody = document.getElementById('productsTableBody');
            
                    const products = data.items || data.data || data;
                    totalPages = data.totalPages || data.totalPages || 1;
            
                    if (!Array.isArray(products) || products.length === 0) {
                        tbody.innerHTML = '<tr><td colspan="6" class="text-center text-muted py-4">Немає товарів</td></tr>';
                        updatePaginationControls();
                        return;
                    }
            
                    tbody.innerHTML = products.map(product => `
                        <tr>
                            <td class="product-name">${escapeHtml(product.name)}</td>
                            <td>${escapeHtml(product.description || '')}</td>
                            <td class="product-price">${Number(product.price).toFixed(2)} грн</td>
                            <td>${product.quantityAvailable ?? 0}</td>
                            <td>${escapeHtml(product.categoryName || '-')}</td>
                            <td>
                                <div class="action-buttons">
                                    <button class="btn btn-outline-primary btn-sm" onclick="openEditModal('${product.id}')">
                                        Редагувати
                                    </button>
                                    <button class="btn btn-outline-danger btn-sm" onclick="deleteProduct('${product.id}', '${escapeHtml(product.name)}')">
                                        Видалити
                                    </button>
                                </div>
                            </td>
                        </tr>
                    `).join('');
            
                    updatePaginationControls();
                })
                .catch(error => {
                    console.error('Error loading products:', error);
                    document.getElementById('productsTableBody').innerHTML = '<tr><td colspan="6" class="text-center text-danger py-4">Помилка завантаження товарів</td></tr>';
                });
        }

        function updatePaginationControls() {
            let paginationDiv = document.getElementById('paginationControls');
            if (!paginationDiv) {
                const tableContainer = document.querySelector('.table-responsive');
                paginationDiv = document.createElement('div');
                paginationDiv.id = 'paginationControls';
                paginationDiv.className = 'd-flex justify-content-center gap-2 mt-4';
                tableContainer.after(paginationDiv);
            }
    
            if (totalPages <= 1) {
                paginationDiv.innerHTML = '';
                return;
            }
    
            let buttons = '';
    
            buttons += `<button class="btn btn-outline-primary btn-sm" onclick="loadProducts(${currentPage - 1})" ${currentPage === 1 ? 'disabled' : ''}>« Попередня</button>`;
    
            for (let i = 1; i <= totalPages; i++) {
                if (i === currentPage) {
                    buttons += `<button class="btn btn-primary btn-sm" disabled>${i}</button>`;
                } else {
                    buttons += `<button class="btn btn-outline-primary btn-sm" onclick="loadProducts(${i})">${i}</button>`;
                }
            }
    
            buttons += `<button class="btn btn-outline-primary btn-sm" onclick="loadProducts(${currentPage + 1})" ${currentPage === totalPages ? 'disabled' : ''}>Наступна »</button>`;
    
            paginationDiv.innerHTML = buttons;
        }

        let categories = [];

        function loadCategories() {
            fetch('/api/categories')
                .then(response => response.json())
                .then(data => {
                    categories = Array.isArray(data) ? data : (data.items || data.data || []);
            
                    const addCategorySelect = document.getElementById('addCategorySelect');
                    if (addCategorySelect) {
                        addCategorySelect.innerHTML = '<option value="">Оберіть категорію</option>' +
                            categories.map(cat => `<option value="${cat.id}">${escapeHtml(cat.name)}</option>`).join('');
                    }
            
                    const editCategorySelect = document.getElementById('editCategorySelect');
                    if (editCategorySelect) {
                        editCategorySelect.innerHTML = '<option value="">Оберіть категорію</option>' +
                            categories.map(cat => `<option value="${cat.id}">${escapeHtml(cat.name)}</option>`).join('');
                    }
                })
                .catch(error => console.error('Error loading categories:', error));
        }


        function addProduct() {
            const product = {
                name: document.getElementById('addName').value,
                description: document.getElementById('addDesc').value,
                price: parseFloat(document.getElementById('addPrice').value),
                quantityAvailable: parseInt(document.getElementById('addQty').value),
                categoryId: document.getElementById('addCategorySelect').value,
                imageUrl: document.getElementById('addImageUrl').value || null
            };
            console.log('Sending product:', product);

            fetch('/api/products', {
                method: 'POST',
                headers: { 
                    'Content-Type': 'application/json',
                    'Authorization': `Bearer ${token}`
                },
                body: JSON.stringify(product)
            })
            .then(response => {
                console.log('Response status:', response.status);
                if (response.ok) {
                    document.getElementById('addProductForm').reset();
                    loadProducts();
                } else {
                    return response.text().then(text => alert('Помилка при додаванні товару: ' + text));
                }
            })
            .catch(error => console.error('Error:', error));
        }

        function openEditModal(id) {
            fetch(`/api/products/${id}`)
                .then(response => response.json())
                .then(product => {
                    document.getElementById('editProductId').value = product.id;
                    document.getElementById('editName').value = product.name || '';
                    document.getElementById('editDesc').value = product.description || '';
                    document.getElementById('editPrice').value = product.price || 0;
                    document.getElementById('editQuantity').value = product.quantityAvailable || 0;
                    document.getElementById('editCategorySelect').value = product.categoryId || '';
                    document.getElementById('editImageUrl').value = product.imageUrl || '';
                    editModal.show();
                })
                .catch(error => {
                    console.error('Error loading product details:', error);
                    alert('Помилка завантаження даних товару');
                });
        }

        function saveChanges() {
            const id = document.getElementById('editProductId').value;
            
            const updatedProduct = {};
            
            const name = document.getElementById('editName').value;
            if (name) updatedProduct.name = name;
            
            const description = document.getElementById('editDesc').value;
            if (description) updatedProduct.description = description;
            
            const price = parseFloat(document.getElementById('editPrice').value);
            if (!isNaN(price)) updatedProduct.price = price;
            
            const quantity = parseInt(document.getElementById('editQuantity').value);
            if (!isNaN(quantity)) updatedProduct.quantityAvailable = quantity;
            
            const categoryId = document.getElementById('editCategorySelect').value;
            if (categoryId) updatedProduct.categoryId = categoryId;

            const imageUrl = document.getElementById('editImageUrl').value;
            if (imageUrl) updatedProduct.imageUrl = imageUrl;

            fetch(`/api/products/${id}`, {
                method: 'PATCH',
                headers: { 
                    'Content-Type': 'application/json',
                    'Authorization': `Bearer ${token}`
                },
                body: JSON.stringify(updatedProduct)
            })
            .then(response => {
                if (response.ok) {
                    editModal.hide();
                    loadProducts();
                } else {
                    return response.text().then(text => alert('Помилка при оновленні товару: ' + text));
                }
            })
            .catch(error => console.error('Error:', error));
        }

        function deleteProduct(id, name) {
            if (confirm(`Ви впевнені, що хочете видалити товар "${name}"? Цю дію не можна скасувати.`)) {
                fetch(`/api/products/${id}`, {
                    method: 'DELETE',
                    headers: { 'Authorization': `Bearer ${token}`}
                })
                .then(response => {
                    if (response.ok) {
                        loadProducts();
                    } else if (response.status === 404) {
                        alert('Товар не знайдено');
                    } else {
                        alert('Помилка при видаленні товару');
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('Помилка при видаленні товару');
                });
            }
        }

        function escapeHtml(str) {
            if (!str) return '';
            return str.replace(/[&<>]/g, function(m) {
                if (m === '&') return '&amp;';
                if (m === '<') return '&lt;';
                if (m === '>') return '&gt;';
                return m;
            });
        }
    </script>
</body>
</html>