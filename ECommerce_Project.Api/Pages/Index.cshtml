@page
@model IndexModel
@{
    ViewData["Title"] = "Каталог прикрас";
}

<div class="container mt-4">
    <div class="text-center mb-5">
        <h1 class="display-4" style="font-family: 'Georgia', serif;">Jewelry Boutique</h1>
        <p class="text-muted">Ексклюзивні прикраси для особливих моментів</p>
    </div>

    <div id="catalog-container" class="row g-4">
        <div class="text-center w-100" id="loading-spinner">
            <div class="spinner-border text-secondary" role="status">
                <span class="visually-hidden">Завантаження...</span>
            </div>
        </div>
    </div>
</div>

    <script src="~/js/site.js" asp-append-version="true"></script>