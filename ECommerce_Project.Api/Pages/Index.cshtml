@page
@model IndexModel
@{
    ViewData["Title"] = "Каталог прикрас";
}

<div class="container mt-4">
    <div class="text-center mb-5">
        <h1 class="display-4" style="font-family: 'Georgia', serif;">Jewelry Boutique</h1>
        <p class="text-muted">Ексклюзивні прикраси для особливих моментів</p>
    </div>

    <div class="row mb-4 justify-content-center">
        <div class="col-md-5 mb-2">
            <input type="text" id="searchInput" class="form-control rounded-0" placeholder="Пошук прикрас...">
        </div>
        <div class="col-md-4 mb-2">
            <select id="categoryFilter" class="form-select rounded-0">
                <option value="">Всі категорії</option>
            </select>
        </div>
        <div class="col-md-2 mb-2">
            <button class="btn btn-dark w-100 rounded-0" onclick="applyFilters()">Знайти</button>
        </div>
    </div>

    <div id="catalog-container" class="row g-4">
        <div class="text-center w-100" id="loading-spinner">
            <div class="spinner-border text-secondary" role="status">
                <span class="visually-hidden">Завантаження...</span>
            </div>
        </div>
    </div>

    <div id="pagination-container" class="d-flex justify-content-center mt-5 mb-5">
    </div>
</div>