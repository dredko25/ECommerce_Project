@page
@{
    ViewData["Title"] = "Реєстрація";
}
<div class="container mt-5" style="max-width: 400px;">
    <h2 class="text-center mb-4">Створення акаунту</h2>
    <form id="registerForm" onsubmit="handleRegister(event)">
        <div class="mb-3">
            <label class="form-label">Ім'я</label>
            <input type="text" id="regFirstName" class="form-control" required>
        </div>
        <div class="mb-3">
            <label class="form-label">Прізвище</label>
            <input type="text" id="regLastName" class="form-control" required>
        </div>
        <div class="mb-3">
            <label class="form-label">Телефон</label>
            <input type="text" id="regPhone" class="form-control" required>
        </div>
        <div class="mb-3">
            <label class="form-label">Email</label>
            <input type="email" id="regEmail" class="form-control" required>
        </div>
        <div class="mb-4">
            <label class="form-label">Пароль</label>
            <input type="password" id="regPassword" class="form-control" required minlength="8">
        </div>
        <button type="submit" class="btn btn-dark w-100 rounded-0">ЗАРЕЄСТРУВАТИСЯ</button>
        <p class="text-center mt-3"><a href="/Login" class="text-muted">Вже є акаунт? Увійти</a></p>
    </form>
</div>